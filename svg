#!/usr/bin/env python3
"""
Wrapper to run a Python program in export mode.

Usage:
  python3 svg tonality_route.py --from C --to c
"""

from __future__ import annotations

import subprocess
import sys


def main() -> int:
    if len(sys.argv) < 2:
        print("Usage: python3 svg <program.py> [args...]")
        return 1

    program = sys.argv[1]
    args = sys.argv[2:]

    if "--export" not in args:
        args = ["--export"] + args

    cmd = [sys.executable, program] + args
    completed = subprocess.run(cmd)
    return completed.returncode


if __name__ == "__main__":
    raise SystemExit(main())
